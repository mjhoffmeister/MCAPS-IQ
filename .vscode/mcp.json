{
	"servers": {
		"workiq": {
			"command": "npx",
			"args": [
				"-y",
				"@microsoft/workiq",
				"mcp"
			],
			"type": "stdio"
		},
		"msx-crm": {
			"type": "stdio",
			"command": "node",
			"args": [
				"mcp/msx/src/index.js"
			],
			"env": {
				"MSX_CRM_URL": "https://microsoftsales.crm.dynamics.com",
				"MSX_TENANT_ID": "72f988bf-86f1-41af-91ab-2d7cd011db47"
			}
		},

		// Optional: Obsidian Intelligence Layer (OIL) — knowledge layer MCP server
		// https://github.com/JinLee794/Obsidian-Intelligence-Layer
		// "oil": {
		// 	"type": "stdio",
		// 	"command": "node",
		// 	"args": ["${input:oilServerPath}"],
		// 	"env": {
		// 		"OBSIDIAN_VAULT_PATH": "${input:obsidianVaultPath}"
		// 	}
		// 	// Provides 22 domain-specific tools: get_customer_context, prepare_crm_prefetch,
		// 	// search_vault, query_notes, patch_note, promote_findings, check_vault_health, etc.
		// 	// Setup: Clone https://github.com/JinLee794/Obsidian-Intelligence-Layer
		// 	// Run: npm install && npm run build in the OIL directory
		// 	// If not configured, all workflows fall back to stateless CRM-only operation (no breakage).
		// },

	},
	"inputs": [
		{
			"id": "oilServerPath",
			"type": "promptString",
			"description": "Absolute path to the OIL dist/index.js (e.g., /Users/you/Obsidian-Intelligence-Layer/dist/index.js)",
			"default": "${env:OIL_SERVER_PATH}"
		},
		{
			"id": "obsidianVaultPath",
			"type": "promptString",
			"description": "Absolute path to your Obsidian vault directory",
			"default": "${env:OBSIDIAN_VAULT_PATH}"
		}
	]
}