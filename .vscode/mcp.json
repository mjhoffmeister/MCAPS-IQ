{
	"inputs": [
		{
			"id": "vault_path",
			"type": "promptString",
			"description": "Absolute path to your Obsidian vault",
		}
	],
	"servers": {
		"msx": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@microsoft/msx-mcp-server@latest"]
		},
		"oil": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@jinlee794/obsidian-intelligence-layer@latest", "mcp"],
			"env": {
				"OBSIDIAN_VAULT_PATH": "${input:vault_path}"
			}
		},
		
		
