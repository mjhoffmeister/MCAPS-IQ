# Route scoped packages to GitHub Packages registry.
# This file ships with the repo so all users get the correct registry
# routing automatically on `npm install` — no manual .npmrc editing.
#
# Auth tokens are NOT stored here (they go in the user-level ~/.npmrc).
# If you see 401 errors, run:  npm run setup  — it will guide you.

@microsoft:registry=https://npm.pkg.github.com
@jinlee794:registry=https://npm.pkg.github.com
